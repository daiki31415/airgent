{
	"name": "airgent",
	"version": "0.1.0-alpha.1",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"airgent": "bun run index.ts",
		"build": "bun build index.ts --outfile dist/airgent --target bun --compile",
		"dev": "bun --watch run index.ts",
		"lint": "bunx @biomejs/biome check .",
		"typecheck": "bunx tsc --noEmit",
		"pretest": "node scripts/setup-test-stubs.mjs",
		"test": "bun test --isolate"
	},
	"engines": {
		"bun": ">=1.2.0"
	},
	"packageManager": "bun@1.3.14",
	"devDependencies": {
		"@biomejs/biome": "latest",
		"@types/bun": "latest"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@opentui/core": "^0.2.12",
		"bzip2": "^0.1.1",
		"xz": "^2.0.2"
	}
}
