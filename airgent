    ].join(`
`));
    const p = this.config.persona;
    layers.push([
      `[Persona: ${p.name}]`,
      `Role: ${p.role}`,
      `Tone: ${p.tone}`,
      ...p.rules.map((r) => `- ${r}`)
    ].join(`
`));
    layers.push([
      "[Runtime]",
      `Max tokens per response: ${this.config.models.generate.maxTokens}`,
      `Temperature: ${this.config.models.generate.temperature}`,
      `Debug: ${this.config.settings.debug}`
    ].join(`
`));
