var logger = rootLogger.child("api");

class OpenCodeAPI {
  baseUrl;
  authHeader = null;
  constructor(options) {
    this.baseUrl = (options?.baseUrl || process.env.OPENCODE_BASE_URL || "http://127.0.0.1:4096").replace(/\/+$/, "");
    const username = process.env.OPENCODE_SERVER_USERNAME || "opencode";
    const password = options?.password || process.env.OPENCODE_SERVER_PASSWORD || "";
    if (password) {
      this.authHeader = "Basic " + btoa(`${username}:${password}`);
    }
  }
  headers() {
    const h = { "Content-Type": "application/json" };
    if (this.authHeader)
      h.Authorization = this.authHeader;
    return h;
  }
  async healthCheck() {
    try {
      const res = await fetch(`${this.baseUrl}/global/health`, { headers: this.headers() });
      if (!res.ok)
        return { healthy: false };
      const data = await res.json();
      return data;
    } catch {
      return { healthy: false };
    }
  }
  async listProviders() {
    const res = await fetch(`${this.baseUrl}/provider`, { headers: this.headers() });
    if (!res.ok)
      throw new Error(`Failed to list providers: ${res.status}`);
    return res.json();
  }
  async getAuthMethods() {
    const res = await fetch(`${this.baseUrl}/provider/auth`, { headers: this.headers() });
    if (!res.ok)
      throw new Error(`Failed to get auth methods: ${res.status}`);
    return res.json();
  }
  async setAuth(providerId, apiKey) {
    const res = await fetch(`${this.baseUrl}/auth/${providerId}`, {
      method: "PUT",
      headers: this.headers(),
      body: JSON.stringify({ type: "api", key: apiKey })
    });
    if (!res.ok)
      throw new Error(`Failed to set auth for ${providerId}: ${res.status}`);
    return true;
  }
  async createSession(title) {
    const res = await fetch(`${this.baseUrl}/session`, {
      method: "POST",
      headers: this.headers(),
      body: JSON.stringify({ title })
    });
    if (!res.ok)
      throw new Error(`Failed to create session: ${res.status}`);
    return res.json();
  }
  async listSessions() {
    const res = await fetch(`${this.baseUrl}/session`, { headers: this.headers() });
    if (!res.ok)
      throw new Error(`Failed to list sessions: ${res.status}`);
    return res.json();
  }
  async getSession(id) {
    const res = await fetch(`${this.baseUrl}/session/${id}`, { headers: this.headers() });
    if (!res.ok)
      throw new Error(`Failed to get session: ${res.status}`);
    return res.json();
  }
  async deleteSession(id) {
    const res = await fetch(`${this.baseUrl}/session/${id}`, {
      method: "DELETE",
      headers: this.headers()
    });
    if (!res.ok)
      throw new Error(`Failed to delete session: ${res.status}`);
    return res.json();
  }
  async abortSession(id) {
    const res = await fetch(`${this.baseUrl}/session/${id}/abort`, {
      method: "POST",
      headers: this.headers()
    });
    if (!res.ok)
      throw new Error(`Failed to abort session: ${res.status}`);
    return res.json();
  }
  async sendMessage(sessionId, model, text, options) {
    const body = {
      model,
      parts: [{ type: "text", text }]
    };
    if (options?.system)
      body.system = options.system;
    if (options?.noReply)
      body.noReply = true;
    const res = await fetch(`${this.baseUrl}/session/${sessionId}/message`, {
      method: "POST",
      headers: this.headers(),
      body: JSON.stringify(body)
    });
    if (!res.ok) {
      const errText = await res.text().catch(() => "");
      throw new Error(`Failed to send message: ${res.status} ${errText.slice(0, 200)}`);
    }
    return res.json();
  }
  async listMessages(sessionId, limit) {
    const url = limit ? `${this.baseUrl}/session/${sessionId}/message?limit=${limit}` : `${this.baseUrl}/session/${sessionId}/message`;
