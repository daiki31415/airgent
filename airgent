import * as fs3 from "fs";
import * as path3 from "path";
var SKILLS_DIR = path3.join(process.env.HOME || "/home/daiki", ".config", "Airgent", "skills");

class SkillsManager {
  index = { skills: [] };
  loadedSkills = new Map;
  logger = rootLogger.child("skills");
  constructor() {
    this.loadIndex();
  }
  getIndex() {
    return this.index;
  }
  getActiveSkills() {
    return Array.from(this.loadedSkills.keys());
  }
  loadSkill(name) {
    if (this.loadedSkills.has(name)) {
      return this.loadedSkills.get(name);
    }
    const summary = this.index.skills.find((s) => s.name === name);
    if (!summary) {
      this.logger.warn(`Skill not found: ${name}`);
      return null;
    }
    try {
      const content = fs3.readFileSync(summary.filePath, "utf-8");
      const skill = {
        name: summary.name,
        description: summary.description,
        tags: summary.tags,
        content,
        version: "1.0"
      };
      this.loadedSkills.set(name, skill);
      this.logger.info(`Loaded skill: ${name}`);
      return skill;
    } catch (err) {
      this.logger.warn(`Failed to load skill ${name}: ${err}`);
      return null;
    }
  }
  injectSkill(prompt, skillName) {
    const skill = this.loadSkill(skillName);
    if (!skill) {
      return prompt.replace(new RegExp(`\\{\\{skill:${skillName}\\}\\}`, "g"), "");
    }
    const injection = `[Skill: ${skill.name}]
${skill.content}
[/Skill]`;
    return prompt.replace(new RegExp(`\\{\\{skill:${skillName}\\}\\}`, "g"), injection);
  }
  loadIndex() {
    const indexPath = path3.join(SKILLS_DIR, "index.json");
    try {
      if (fs3.existsSync(indexPath)) {
        const raw = fs3.readFileSync(indexPath, "utf-8");
        this.index = JSON.parse(raw);
        this.logger.info(`Loaded ${this.index.skills.length} skills from index`);
      } else {
        this.logger.info("No skills index found, creating default");
        fs3.mkdirSync(SKILLS_DIR, { recursive: true });
        this.index = { skills: [] };
        fs3.writeFileSync(indexPath, JSON.stringify(this.index, null, 2));
      }
    } catch (err) {
      this.logger.warn(`Failed to load skills: ${err}`);
      this.index = { skills: [] };
    }
  }
}

